{
  "name": "@veriqore/schema",
  "version": "0.1.0",
  "private": true,
  "description": "QPR (Quantum Performance Record) JSON Schema — single source of truth — with generated TypeScript types and an Ajv validator",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/qpr-0.2.0.schema.json": "./schema/qpr-0.2.0.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "generate": "node scripts/generate-ts.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
